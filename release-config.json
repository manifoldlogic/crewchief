{
  "$schema": "./release-config.schema.json",
  "description": "Coordinated release configuration for CrewChief packages",
  "releaseOrder": [
    "@crewchief/cli",
    "@crewchief/maproom-mcp",
    "vscode-maproom"
  ],
  "packages": {
    "@crewchief/cli": {
      "path": "packages/cli",
      "publishTo": ["npm"],
      "dependencies": [],
      "schemaVersion": 1,
      "notes": "Core CLI - must be released first as other packages depend on it"
    },
    "@crewchief/maproom-mcp": {
      "path": "packages/maproom-mcp",
      "publishTo": ["npm"],
      "dependencies": ["@crewchief/cli"],
      "requiredCliVersion": ">=1.5.0",
      "schemaVersion": 1,
      "notes": "MCP server - docs reference CLI for migrations/scanning"
    },
    "vscode-maproom": {
      "path": "packages/vscode-maproom",
      "publishTo": ["vscode-marketplace", "open-vsx"],
      "dependencies": [],
      "schemaVersion": 1,
      "notes": "VSCode extension - bundles own binary, self-contained"
    }
  },
  "rustBinary": {
    "crate": "crates/maproom",
    "name": "crewchief-maproom",
    "platforms": ["linux-x64", "linux-arm64", "darwin-x64", "darwin-arm64", "win32-x64"]
  },
  "validation": {
    "requireCleanWorkingTree": true,
    "requirePassingTests": true,
    "requireVersionBump": true,
    "blockOnUnreleasedDependencies": true
  }
}
