# CrewChief Web UI Environment Configuration
# Copy this file to .env and update values for your environment

# ===================
# Database Configuration
# ===================
CREWCHIEF_DB_HOST=localhost
CREWCHIEF_DB_PORT=5432
CREWCHIEF_DB_NAME=crewchief
CREWCHIEF_DB_USER=postgres
CREWCHIEF_DB_PASSWORD=your_secure_password_here
CREWCHIEF_DB_SSL=false

# Database Connection Pool
CREWCHIEF_DB_POOL_MAX=20
CREWCHIEF_DB_POOL_MIN=5

# ===================
# Redis Configuration
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ===================
# Application Configuration
# ===================
# Port for the web UI server
WEB_UI_PORT=3456

# Session and JWT secrets (MUST be changed in production)
SESSION_SECRET=your_session_secret_change_in_production
JWT_SECRET=your_jwt_secret_change_in_production

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3456

# ===================
# Frontend Configuration (Vite)
# ===================
# API base URL for frontend
VITE_API_BASE_URL=http://localhost:3456/api

# WebSocket URL for real-time features
VITE_WS_URL=ws://localhost:3456

# ===================
# Development Settings
# ===================
# Node environment (development, production, test)
NODE_ENV=development

# Debug namespace for development (use * for all)
DEBUG=crewchief:*

# ===================
# Security Settings
# ===================
# Rate limiting (requests per minute per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session expiration (in milliseconds)
SESSION_TIMEOUT_MS=86400000  # 24 hours

# Cookie settings
COOKIE_SECURE=false  # Set to true in production with HTTPS
COOKIE_SAME_SITE=lax

# ===================
# Monitoring & Observability
# ===================
# Health check timeout
HEALTH_CHECK_TIMEOUT=5000

# Metrics collection
ENABLE_METRICS=true
METRICS_PORT=9090

# ===================
# File Upload Settings
# ===================
# Maximum file size for uploads (in bytes)
MAX_FILE_SIZE=10485760  # 10MB

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=.txt,.md,.json,.log

# ===================
# Database Migration Settings
# ===================
# Auto-run migrations on startup
AUTO_MIGRATE=true

# Migration timeout (in milliseconds)
MIGRATION_TIMEOUT=30000

# ===================
# Cache Settings
# ===================
# Cache TTL for various data types (in seconds)
CACHE_TTL_SESSION=3600      # 1 hour
CACHE_TTL_SEARCH=1800       # 30 minutes
CACHE_TTL_PREFERENCES=7200  # 2 hours
CACHE_TTL_WORKTREE=300      # 5 minutes

# ===================
# Docker Compose Overrides
# ===================
# These are used by docker-compose.yml

# PostgreSQL in Docker
POSTGRES_DB=crewchief
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Redis in Docker
REDIS_PASSWORD=your_redis_password_here

# ===================
# Development Tools (Optional)
# ===================
# pgAdmin credentials (for development)
PGADMIN_DEFAULT_EMAIL=admin@crewchief.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Redis Commander credentials
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin

# ===================
# Production Security
# ===================
# These should be set in production environments

# SSL/TLS certificates
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Trusted proxy IPs (for secure headers)
TRUSTED_PROXIES=127.0.0.1,::1

# Content Security Policy
CSP_REPORT_URI=https://your-csp-report-endpoint.com/report