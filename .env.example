# CrewChief Environment Configuration
# Copy this file to .env and update values for your environment

# ===================
# Maproom Configuration
# ===================
# PostgreSQL connection URL for Maproom semantic search
# Format: postgres://user:password@host:port/database
PG_DATABASE_URL=postgres://postgres:your_password@localhost:5432/maproom

# ===================
# Development Settings
# ===================
# Node environment (development, production, test)
NODE_ENV=development

# Debug namespace for development (use * for all)
DEBUG=crewchief:*
