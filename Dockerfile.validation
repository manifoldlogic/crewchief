FROM node:18-slim

# Install git (required for worktrees)
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package.json files for workspace
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/cli/package.json ./packages/cli/
COPY packages/daemon-client/package.json ./packages/daemon-client/
COPY packages/maproom-mcp/package.json ./packages/maproom-mcp/
COPY packages/vscode-maproom/package.json ./packages/vscode-maproom/
COPY crates/maproom/Cargo.toml ./crates/maproom/

# Install pnpm
RUN npm install -g pnpm

# Install dependencies
RUN pnpm install --frozen-lockfile --filter @crewchief/cli...

# Copy source code
COPY packages/cli ./packages/cli
COPY tsconfig.json ./

# Build CLI
RUN pnpm --filter @crewchief/cli build

# Create a mock git repo for testing
RUN git init && \
    git config --global user.email "test@example.com" && \
    git config --global user.name "Test User" && \
    git commit -m "Initial commit" --allow-empty

# Entry point
CMD ["node", "packages/cli/dist/cli/index.js", "spawn", "claude", "docker-test", "--headless"]

