{
  "mcpServers": {
    "maproom": {
      "command": "node",
      "args": [
        "/workspace/packages/maproom-mcp/bin/cli.cjs"
      ],
      "env": {
        "MAPROOM_DATABASE_URL": "sqlite://~/.maproom/maproom.db",
        "MAPROOM_EMBEDDING_PROVIDER": "ollama",
        "CREWCHIEF_MAPROOM_BIN": "/workspace/target/release/crewchief-maproom"
      }
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa"
    },
    "rust-language-server": {
      "command": "mcp-language-server",
      "args": [
        "--workspace",
        "/workspace",
        "--lsp",
        "rust-analyzer"
      ]
    },
    "ts-language-server": {
      "command": "mcp-language-server",
      "args": [
        "--workspace",
        "/workspace",
        "--lsp",
        "vtsls",
        "--",
        "--stdio"
      ]
    },
    "Ref": {
      "type": "http",
      "url": "https://api.ref.tools/mcp",
      "headers": {
        "x-ref-api-key": "ref-a69f62a09e5489964eeb"
      }
    }
  }
}