{
  "env": {
    "SDD_ROOT_DIR": "/workspace/_SPECS/crewchief",
    "MAPROOM_DB_ROOT": "/home/vscode/.maproom",
    "MAPROOM_EMBEDDING_PROVIDER": "google",
    "GOOGLE_PROJECT_ID": "crewchief-476600"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.devcontainer/scripts/maproom-sync start || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ssh -i ~/.ssh/id_ed25519 danielbushman@host.docker.internal 'afplay /Users/danielbushman/git/manifoldlogic/home/.claude/audio/scale-e6-14577.mp3'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"systemMessage\": \"💬 %s\"}' \"$(TZ='America/Denver' date '+%Y-%m-%d %H:%M:%S %Z')\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "crewchief": {
      "source": {
        "source": "directory",
        "path": "/workspace/repos/claude-code-plugins/claude-code-plugins"
      }
    }
  }
}
