# Maproom LOCAL Environment Configuration
# Copy this file to .env and customize as needed

# Port Configuration
# Override default ports if they conflict with existing services
OLLAMA_PORT=11434
MAPROOM_PORT=3000

# Workspace Path
# Path to your codebase (mounted read-only into maproom container)
# Default: /workspace
HOST_WORKSPACE=/workspace

# Logging Configuration
# Log level for Maproom service
# Options: trace, debug, info, warn, error
RUST_LOG=info

# PostgreSQL Configuration
# Note: Changing these requires updating docker-compose.yml
# POSTGRES_DB=maproom
# POSTGRES_USER=maproom
# POSTGRES_PASSWORD=maproom

# Advanced: Ollama Configuration
# Uncomment to use a different Ollama endpoint (external service)
# EMBEDDING_API_ENDPOINT=http://your-ollama-host:11434

# Advanced: Resource Limits
# Uncomment to set resource limits (requires modifying docker-compose.yml)
# POSTGRES_MEMORY_LIMIT=2g
# OLLAMA_MEMORY_LIMIT=4g
# MAPROOM_MEMORY_LIMIT=1g
