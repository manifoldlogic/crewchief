{
  "name": "@crewchief/maproom-mcp",
  "version": "2.0.6",
  "type": "module",
  "description": "Maproom MCP server with choice of embedding providers - one setup command, then zero config",
  "main": "dist/index.js",
  "bin": {
    "maproom-mcp": "./bin/cli.cjs"
  },
  "files": [
    "bin",
    "config/docker-compose.yml",
    "config/Dockerfile.mcp-server",
    "config/init.sql",
    "dist/",
    "src/",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "setup": "node bin/cli.cjs setup",
    "scan": "node bin/cli.cjs scan",
    "watch": "node bin/cli.cjs watch",
    "test": "node tests/connection-fallback.test.cjs && node tests/run-blob-sha-tests.cjs",
    "test:connection": "node tests/connection-fallback.test.cjs",
    "test:blob-sha": "node tests/run-blob-sha-tests.cjs",
    "test:vitest": "vitest run",
    "test:integration": "vitest run tests/integration/",
    "dev": "node bin/cli.cjs",
    "prepublishOnly": "tsc && npm audit --audit-level=high --production",
    "security-check": "pnpm audit --audit-level=moderate",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "keywords": [
    "mcp",
    "embeddings",
    "ollama",
    "semantic-search",
    "code-search",
    "local-llm",
    "docker",
    "postgresql",
    "pgvector"
  ],
  "author": "CrewChief",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danielbushman/crewchief.git",
    "directory": "packages/maproom-mcp"
  },
  "bugs": {
    "url": "https://github.com/danielbushman/crewchief/issues"
  },
  "homepage": "https://github.com/danielbushman/crewchief/tree/main/packages/maproom-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "execa": "^8.0.1",
    "lru-cache": "^11.2.2",
    "pg": "^8.11.3",
    "pino": "^8.16.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.3"
  }
}
