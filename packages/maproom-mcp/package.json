{
  "name": "maproom-mcp",
  "version": "0.1.1",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "maproom-mcp": "bin/cli.js"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "postinstall": "node ./dist/postinstall.js || true",
    "release:patch": "npm version patch --no-git-tag-version --workspaces=false && pnpm publish --access public",
    "release:minor": "npm version minor --no-git-tag-version --workspaces=false && pnpm publish --access public",
    "release:major": "npm version major --no-git-tag-version --workspaces=false && pnpm publish --access public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "pg": "^8.12.0",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.7.0",
    "tsx": "^4.17.0",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}