{
  "name": "@crewchief/maproom-mcp",
  "version": "3.3.14",
  "type": "module",
  "description": "[DEPRECATED] MCP server for semantic code search with PostgreSQL and pgvector",
  "main": "dist/index.js",
  "bin": {
    "maproom-mcp": "./bin/cli.cjs"
  },
  "files": [
    "bin",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run tests/unit/",
    "test:blob-sha": "node tests/run-blob-sha-tests.cjs",
    "test:vitest": "TEST_MAPROOM_DATABASE_URL=postgresql://maproom:maproom@host.docker.internal:5434/maproom_test vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "TEST_MAPROOM_DATABASE_URL=postgresql://maproom:maproom@host.docker.internal:5434/maproom_test vitest run tests/integration/",
    "test:integration:blob-sha": "node tests/run-blob-sha-tests.cjs",
    "test:benchmark": "TEST_MAPROOM_DATABASE_URL=postgresql://maproom:maproom@host.docker.internal:5434/maproom_test vitest run tests/integration/search-quality.test.ts --reporter=verbose",
    "test:semrank": "TEST_MAPROOM_DATABASE_URL=postgresql://maproom:maproom@host.docker.internal:5434/maproom_test vitest run tests/integration/regression.test.ts tests/integration/search-quality.test.ts tests/integration/semrank-edge-cases.test.ts",
    "test:sqlite": "vitest run tests/integration/sqlite-backend.test.ts",
    "test:all": "pnpm run test:blob-sha && pnpm run test:vitest",
    "dev": "node bin/cli.cjs",
    "prepublishOnly": "tsc",
    "security-check": "pnpm audit --audit-level=moderate",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "keywords": [
    "mcp",
    "embeddings",
    "semantic-search",
    "code-search",
    "postgresql",
    "pgvector"
  ],
  "author": "CrewChief",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/manifoldlogic/crewchief.git",
    "directory": "packages/maproom-mcp"
  },
  "bugs": {
    "url": "https://github.com/manifoldlogic/crewchief/issues"
  },
  "homepage": "https://github.com/manifoldlogic/crewchief/tree/main/packages/maproom-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "execa": "^8.0.1",
    "lru-cache": "^11.2.2",
    "pg": "^8.11.3",
    "pino": "^8.16.2",
    "tsx": "^4.20.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.3"
  }
}
