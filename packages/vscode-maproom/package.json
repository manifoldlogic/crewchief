{
  "name": "vscode-maproom",
  "displayName": "Maproom Semantic Search",
  "description": "Semantic code search powered by Maproom - find code by concept, not just text",
  "version": "0.1.0",
  "publisher": "crewchief",
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "search",
    "semantic",
    "code search",
    "tree-sitter",
    "embeddings",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/danielbushman/crewchief.git",
    "directory": "packages/vscode-maproom"
  },
  "bugs": {
    "url": "https://github.com/danielbushman/crewchief/issues"
  },
  "homepage": "https://github.com/danielbushman/crewchief/tree/main/packages/vscode-maproom#readme",
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "maproom.showOutput",
        "title": "Maproom: Show Output"
      },
      {
        "command": "maproom.setup",
        "title": "Maproom: Setup"
      },
      {
        "command": "maproom.restartWatchers",
        "title": "Maproom: Restart Watchers",
        "category": "Maproom"
      }
    ]
  },
  "scripts": {
    "prepare:binaries": "node scripts/prepare-binaries.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepackage": "pnpm run prepare:binaries && pnpm run compile",
    "vsce:package": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vscode/vsce": "^3.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
