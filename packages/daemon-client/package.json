{
  "name": "@crewchief/daemon-client",
  "version": "0.1.0",
  "description": "TypeScript client library for communicating with the maproom daemon via JSON-RPC",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "maproom",
    "daemon",
    "json-rpc",
    "search",
    "code-search",
    "crewchief"
  ],
  "author": "CrewChief",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/manifoldlogic/crewchief.git",
    "directory": "packages/daemon-client"
  },
  "bugs": {
    "url": "https://github.com/manifoldlogic/crewchief/issues"
  },
  "homepage": "https://github.com/manifoldlogic/crewchief/tree/main/packages/daemon-client#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}