{
  "mcpServers": {
    "maproom": {
      "command": "docker",
      "args": ["exec", "-i", "maproom-mcp", "node", "/app/dist/index.js"],
      "env": {
        "MAPROOM_EMBEDDING_PROVIDER": "openai",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      }
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-481a49a8-35bc-40a2-8441-8f5c2e40b55f"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "github": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "ghcr.io/github/github-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "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"
      },
      "tool_configuration": {
        "enabled": true,
        "allowed_tools": [
          "create_pull_request",
          "get_pull_request",
          "get_pull_request_diff",
          "get_pull_request_files",
          "get_pull_request_review_comments",
          "get_pull_request_reviews",
          "list_pull_requests",
          "create_branch",
          "cancel_workflow_run",
          "get_job_logs",
          "get_workflow_run",
          "get_workflow_run_logs",
          "get_workflow_run_usage",
          "list_workflow_jobs",
          "list_workflow_run_artifacts",
          "list_workflow_runs",
          "list_workflows",
          "rerun_workflow_run",
          "run_workflow"
        ]
      }
    }
  }
}
