{
  "name": "crewchief",
  "version": "0.1.6",
  "private": false,
  "description": "CrewChief: Multi-agent orchestration CLI for coordinating AI agents via git worktrees and tmux.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "crewchief": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "crewchief.config.sample.ts"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts --help",
    "build": "tsup src/cli/index.ts --format esm --dts --sourcemap --minify --out-dir dist --clean",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier -w .",
    "prepublishOnly": "pnpm build",
    "release:patch": "node ./scripts/release.mjs patch",
    "release:minor": "node ./scripts/release.mjs minor",
    "release:major": "node ./scripts/release.mjs major"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "chalk": "^5.0.0",
    "commander": "^11.0.0",
    "inquirer": "^9.0.0",
    "simple-git": "^3.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac"
}
