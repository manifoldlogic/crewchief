{
  "name": "@crewchief/cli",
  "version": "1.0.0",
  "private": false,
  "description": "CrewChief: Multi-agent orchestration CLI for coordinating AI agents via git worktrees and tmux.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "crewchief": "bin/crewchief"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "crewchief.config.example.ts"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts --help",
    "build": "tsup src/cli/index.ts src/postinstall.ts --format esm --dts --sourcemap --minify --out-dir dist --clean",
    "build:rust": "../../scripts/build-and-package.sh",
    "build:all": "pnpm build:rust && pnpm build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "search-optimization:validate-full": "tsx src/search-optimization/scripts/run-full-validation.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm lint && pnpm format:check",
    "fix": "pnpm lint:fix && pnpm format",
    "postinstall": "node ./dist/postinstall.js || true",
    "release:patch": "node ./scripts/release.mjs patch",
    "release:minor": "node ./scripts/release.mjs minor",
    "release:major": "node ./scripts/release.mjs major",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.30",
    "@types/node": "^20.0.0",
    "chalk": "^5.0.0",
    "commander": "^11.0.0",
    "glob": "^11.0.3",
    "ignore": "^7.0.5",
    "inquirer": "^9.0.0",
    "simple-git": "^3.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b"
}
