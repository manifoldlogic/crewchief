{
  "name": "crewchief",
  "version": "0.1.13",
  "private": false,
  "description": "CrewChief: Multi-agent orchestration CLI for coordinating AI agents via git worktrees and tmux.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "crewchief": "bin/crewchief"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "crewchief.config.sample.ts"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts --help",
    "build": "tsup src/cli/index.ts src/postinstall.ts --format esm --dts --sourcemap --minify --out-dir dist --clean",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier -w .",
    "prepublishOnly": "pnpm build",
    "postinstall": "node ./dist/postinstall.js || true",
    "release:patch": "node ./scripts/release.mjs patch",
    "release:minor": "node ./scripts/release.mjs minor",
    "release:major": "node ./scripts/release.mjs major"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "chalk": "^5.0.0",
    "commander": "^11.0.0",
    "inquirer": "^9.0.0",
    "simple-git": "^3.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
