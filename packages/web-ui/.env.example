# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/crewchief_web
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=crewchief
POSTGRES_PASSWORD=your-password
POSTGRES_DB=crewchief_web

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-at-least-32-characters-long

# Redis Configuration (for sessions)
REDIS_URL=redis://localhost:6379

# OAuth Configuration - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth Configuration - Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Server Configuration
PORT=3456
NODE_ENV=development
BASE_URL=http://localhost:3456
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3456,http://localhost:5173

# API Keys (for legacy API access)
API_KEY_1=your-api-key-1
API_KEY_2=your-api-key-2

# Security Configuration
BCRYPT_ROUNDS=12
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30

# Rate Limiting
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
REGISTER_RATE_LIMIT_WINDOW_MS=3600000
REGISTER_RATE_LIMIT_MAX_ATTEMPTS=5

# Email Configuration (for future email verification/password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@crewchief.dev

# Logging
LOG_LEVEL=info