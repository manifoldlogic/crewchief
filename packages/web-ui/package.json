{
  "name": "@crewchief/web-ui",
  "version": "0.1.1",
  "private": false,
  "description": "CrewChief Web UI: A web interface for managing and monitoring CrewChief operations.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently \"PORT=3500 pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx --watch src/server.ts",
    "dev:client": "vite --port 3000",
    "build": "pnpm build:client && pnpm build:server",
    "build:server": "tsup src/server.ts --format esm --dts --sourcemap --minify --out-dir dist --clean",
    "build:client": "vite build",
    "preview": "vite preview",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:ci": "pnpm test:coverage && pnpm test:e2e",
    "test:comprehensive": "./scripts/test-all.sh",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm lint && pnpm format:check",
    "fix": "pnpm lint:fix && pnpm format",
    "db": "tsx src/db/cli.ts",
    "db:setup": "tsx src/db/cli.ts setup",
    "db:migrate": "tsx src/db/cli.ts migrate",
    "db:migrate:status": "tsx src/db/cli.ts migrate:status",
    "db:migrate:reset": "tsx src/db/cli.ts migrate:reset",
    "db:seed": "tsx src/db/cli.ts seed",
    "db:health": "tsx src/db/cli.ts health",
    "db:cleanup": "tsx src/db/cli.ts cleanup",
    "db:stats": "tsx src/db/cli.ts stats",
    "docker:build": "../../scripts/docker-build.sh",
    "docker:build:dev": "../../scripts/docker-build.sh -t development",
    "docker:build:prod": "../../scripts/docker-build.sh -t production",
    "docker:up": "../../scripts/docker-run.sh up",
    "docker:up:dev": "../../scripts/docker-run.sh up",
    "docker:up:prod": "../../scripts/docker-run.sh up -e production",
    "docker:down": "../../scripts/docker-run.sh down",
    "docker:logs": "../../scripts/docker-run.sh logs web-ui",
    "docker:shell": "../../scripts/docker-run.sh shell",
    "docker:test": "../../scripts/docker-test.sh"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "commander": "^12.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.5.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^12.10.3",
    "msw": "^2.0.8",
    "postcss": "^8.4.33",
    "prettier": "^3.3.0",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.1.0",
    "vitest": "^1.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
