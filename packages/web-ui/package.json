{
  "name": "@crewchief/web-ui",
  "version": "0.1.1",
  "private": false,
  "description": "CrewChief Web UI: A web interface for managing and monitoring CrewChief operations.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently \"PORT=3500 pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx --watch src/server.ts",
    "dev:client": "vite --port 5173",
    "build": "pnpm build:client && pnpm build:server",
    "build:server": "tsup src/server.ts --format esm --dts --sourcemap --minify --out-dir dist --clean",
    "build:client": "vite build",
    "preview": "vite preview",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:ci": "pnpm test:coverage && pnpm test:e2e",
    "test:comprehensive": "./scripts/test-all.sh",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm lint && pnpm format:check",
    "fix": "pnpm lint:fix && pnpm format",
    "audit": "pnpm audit --audit-level moderate",
    "audit:fix": "pnpm audit --fix",
    "security:check": "pnpm audit && echo 'Checking for outdated packages...' && pnpm outdated",
    "db": "tsx src/db/cli.ts",
    "db:setup": "tsx src/db/cli.ts setup",
    "db:migrate": "tsx src/db/cli.ts migrate",
    "db:migrate:status": "tsx src/db/cli.ts migrate:status",
    "db:migrate:reset": "tsx src/db/cli.ts migrate:reset",
    "db:seed": "tsx src/db/cli.ts seed",
    "db:health": "tsx src/db/cli.ts health",
    "db:cleanup": "tsx src/db/cli.ts cleanup",
    "db:stats": "tsx src/db/cli.ts stats",
    "db:test": "node test-database.js",
    "docker:build": "../../scripts/docker-build.sh",
    "docker:build:dev": "../../scripts/docker-build.sh -t development",
    "docker:build:prod": "../../scripts/docker-build.sh -t production",
    "docker:up": "../../scripts/docker-run.sh up",
    "docker:up:dev": "../../scripts/docker-run.sh up",
    "docker:up:prod": "../../scripts/docker-run.sh up -e production",
    "docker:down": "../../scripts/docker-run.sh down",
    "docker:logs": "../../scripts/docker-run.sh logs web-ui",
    "docker:shell": "../../scripts/docker-run.sh shell",
    "docker:test": "../../scripts/docker-test.sh",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "bcrypt": "^6.0.0",
    "commander": "^12.0.0",
    "compression": "^1.7.4",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "redis": "^5.8.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.22.0",
    "chokidar": "^4.0.3",
    "ignore": "^7.0.5",
    "mime-types": "^3.0.1",
    "@apollo/server": "^5.0.0",
    "@apollo/client": "^3.13.9",
    "@as-integrations/express4": "^1.0.0",
    "@graphql-tools/schema": "^10.0.25",
    "graphql-ws": "^6.0.6",
    "ws": "^8.18.3",
    "body-parser": "^2.2.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-redis-subscriptions": "^2.7.0",
    "ioredis": "^5.7.0",
    "graphql": "^16.11.0",
    "lucide-react": "^0.539.0",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/connect-redis": "^0.0.23",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.5.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^12.10.3",
    "msw": "^2.0.8",
    "postcss": "^8.4.33",
    "prettier": "^3.3.0",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.1.0",
    "vitest": "^1.5.0",
    "@types/mime-types": "^3.0.1",
    "@types/ws": "^8.18.1",
    "@types/body-parser": "^1.19.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
